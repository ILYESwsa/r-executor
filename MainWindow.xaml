<Window x:Class="DiscordOAuthWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Discord OAuth2 Login" Height="760" Width="1100" MinHeight="620" MinWidth="920"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" Margin="12">
      <Button x:Name="LoginButton"
              Content="Login with Discord"
              Width="180"
              Height="36"
              Click="LoginButton_Click"
              Margin="0,0,12,0" />
      <TextBlock x:Name="UserText"
                 VerticalAlignment="Center"
                 FontWeight="SemiBold"
                 Text="Not authenticated" />
    </DockPanel>

    <Grid Grid.Row="1" Margin="12">
      <Border x:Name="WebViewContainer" BorderBrush="#D0D0D0" BorderThickness="1">
        <wv2:WebView2 x:Name="OAuthWebView" />
      </Border>

      <Border x:Name="NativeContentContainer"
              Visibility="Collapsed"
              BorderBrush="#D0D0D0"
              BorderThickness="1"
              Padding="24">
        <StackPanel>
          <TextBlock Text="Authenticated"
                     FontSize="24"
                     FontWeight="Bold"
                     Margin="0,0,0,16" />

          <Image x:Name="AvatarImage"
                 Width="96"
                 Height="96"
                 Margin="0,0,0,12" />

          <TextBlock x:Name="UsernameValue"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Margin="0,0,0,6"
                     Text="Username: -" />

          <TextBlock x:Name="UserIdValue"
                     FontSize="14"
                     Text="User ID: -"
                     Margin="0,0,0,18" />

          <Button Content="Login with another account"
                  Width="220"
                  Height="34"
                  Click="LoginAgainButton_Click" />
        </StackPanel>
      </Border>
    </Grid>

    <TextBlock x:Name="StatusText"
               Grid.Row="2"
               Margin="12"
               Foreground="#444"
               Text="Ready"
               TextWrapping="Wrap" />
  </Grid>
</Window>
