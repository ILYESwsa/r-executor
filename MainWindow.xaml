<Window x:Class="DiscordOAuthWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Discord OAuth Desktop"
        Height="760"
        Width="1120"
        MinHeight="640"
        MinWidth="940"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220"
        Foreground="#E2E8F0">
  <Window.Resources>
    <LinearGradientBrush x:Key="SurfaceGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#111A2E" Offset="0"/>
      <GradientStop Color="#0B1220" Offset="1"/>
    </LinearGradientBrush>

    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#5865F2"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#7C8BFF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#6A75F5"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Margin="14">
    <Border CornerRadius="14"
            BorderBrush="#29324A"
            BorderThickness="1"
            Background="{StaticResource SurfaceGradient}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="16,14,16,10">
          <Button x:Name="LoginButton"
                  Style="{StaticResource PrimaryButton}"
                  Content="Login with Discord"
                  Width="190"
                  Height="38"
                  Click="LoginButton_Click"
                  Margin="0,0,12,0" />

          <TextBlock x:Name="UserText"
                     VerticalAlignment="Center"
                     Foreground="#A5B4FC"
                     FontWeight="SemiBold"
                     Text="Not authenticated" />
        </DockPanel>

        <Grid Grid.Row="1" Margin="16,0,16,14">
          <Border x:Name="WebViewContainer"
                  BorderBrush="#2E3A57"
                  BorderThickness="1"
                  CornerRadius="12"
                  Background="#0E172A">
            <wv2:WebView2 x:Name="OAuthWebView" />
          </Border>

          <Border x:Name="NativeContentContainer"
                  Visibility="Collapsed"
                  BorderBrush="#2E3A57"
                  BorderThickness="1"
                  CornerRadius="12"
                  Background="#0E172A"
                  Padding="26">
            <StackPanel>
              <TextBlock Text="Authenticated"
                         FontSize="28"
                         FontWeight="Bold"
                         Foreground="#C7D2FE"
                         Margin="0,0,0,18" />

              <Border Width="104" Height="104" CornerRadius="52" BorderBrush="#39496F" BorderThickness="1" Margin="0,0,0,14">
                <Image x:Name="AvatarImage" Width="96" Height="96" Margin="4"/>
              </Border>

              <TextBlock x:Name="UsernameValue"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="#E2E8F0"
                         Margin="0,0,0,8"
                         Text="Username: -" />

              <TextBlock x:Name="UserIdValue"
                         FontSize="14"
                         Foreground="#94A3B8"
                         Text="User ID: -"
                         Margin="0,0,0,20" />

              <Button Content="Login with another account"
                      Width="230"
                      Height="36"
                      Style="{StaticResource PrimaryButton}"
                      Click="LoginAgainButton_Click" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Grid.Row="2" Margin="16,0,16,14" Background="#0D1628" CornerRadius="10" Padding="12,10">
          <TextBlock x:Name="StatusText"
                     Foreground="#93C5FD"
                     Text="Ready"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
