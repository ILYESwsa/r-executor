{
  "name": "discord-oauth-electron-app",
  "version": "1.0.0",
  "description": "Electron desktop app with Discord OAuth2 login via Express",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.example.discordoauthdesktop",
    "productName": "DiscordOAuthDesktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": null
  }
}
