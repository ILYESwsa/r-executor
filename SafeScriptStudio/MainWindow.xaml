<Window x:Class="SafeScriptStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Safe Script Studio"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#101319"
        Foreground="#F3F4F6">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#161B24" />
        <SolidColorBrush x:Key="CardBg" Color="#1B2230" />
        <SolidColorBrush x:Key="Accent" Color="#7FA2FF" />
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="8,8,8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D2D8E3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222C3D"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A2232"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#25314A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border CornerRadius="12" BorderBrush="{StaticResource Accent}" BorderThickness="1" Background="{StaticResource PanelBg}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="8,16,8,8">
                    <TextBlock Text="◆" FontSize="28" Foreground="{StaticResource Accent}" HorizontalAlignment="Center"/>
                    <Button x:Name="ScriptsButton" Style="{StaticResource MenuButtonStyle}" Content="Scripts" Click="ScriptsButton_Click"/>
                    <Button x:Name="ConfigButton" Style="{StaticResource MenuButtonStyle}" Content="Config" Click="ConfigButton_Click"/>
                    <Button x:Name="FilesButton" Style="{StaticResource MenuButtonStyle}" Content="Files" Click="FilesButton_Click"/>
                </StackPanel>

                <Border Grid.Column="1" BorderBrush="#2C364A" BorderThickness="1,0,1,0" Background="#131925">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,4,0,12">
                            <Button x:Name="TxtFilterButton" Style="{StaticResource ActionButtonStyle}" Content="TXT" Width="64" Height="36" Click="TxtFilterButton_Click"/>
                            <Button x:Name="AllFilterButton" Style="{StaticResource ActionButtonStyle}" Content="ALL" Width="64" Height="36" Click="AllFilterButton_Click"/>
                        </DockPanel>

                        <TextBox x:Name="ScriptNameTextBox" Grid.Row="1"
                                 Text="SCRIPT NAME"
                                 Background="#1D2533"
                                 Foreground="#E4E7EC"
                                 BorderBrush="{StaticResource Accent}"
                                 BorderThickness="1"
                                 FontSize="28"
                                 FontWeight="Bold"
                                 Padding="8"/>

                        <ListBox x:Name="SavedScriptsList"
                                 Grid.Row="2"
                                 Margin="0,12,0,0"
                                 Background="#0F141E"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 Foreground="#E2E8F0">
                            <ListBoxItem Content="Welcome.lua"/>
                            <ListBoxItem Content="MovementChecks.lua"/>
                            <ListBoxItem Content="EconomyTests.lua"/>
                        </ListBox>
                    </Grid>
                </Border>

                <Grid Grid.Column="2" Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="12,12,12,8">
                        <Border BorderBrush="{StaticResource Accent}" BorderThickness="1" CornerRadius="8" Padding="14,8" Background="#1A2232" DockPanel.Dock="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Script here" FontWeight="SemiBold"/>
                                <TextBlock Text="   ×" Foreground="#AAB4C5"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="NewScriptButton" Content="+" FontSize="26" Width="40" Height="40" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" Foreground="#D7E0F5" Click="NewScriptButton_Click"/>
                    </DockPanel>

                    <TextBox x:Name="EditorTextBox"
                             Grid.Row="1"
                             Margin="12,0,12,12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="26"
                             FontWeight="Bold"
                             Background="#0F141E"
                             Foreground="#F4F4F5"
                             BorderBrush="{StaticResource Accent}"
                             BorderThickness="1"
                             Text="-- local script workspace&#10;print(&quot;Ready&quot;)"/>

                    <DockPanel Grid.Row="2" Margin="12,0,12,12" LastChildFill="False">
                        <Button x:Name="RunLocalButton" Style="{StaticResource ActionButtonStyle}" Content="RUN LOCAL" Width="160" Click="RunLocalButton_Click"/>
                        <Button x:Name="SaveButton" Style="{StaticResource ActionButtonStyle}" Content="SAVE" Width="120" Click="SaveButton_Click"/>
                        <TextBlock x:Name="StatusText"
                                   Text="Ready"
                                   Foreground="#A5B4FC"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="20,0,0,0"/>
                    </DockPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
