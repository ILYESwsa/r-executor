<Window x:Class="SafeScriptStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Safe Script Studio"
        Width="1024"
        Height="620"
        MinWidth="820"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#0C111B"
        Foreground="#F3F4F6">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#121927" />
        <SolidColorBrush x:Key="Accent" Color="#7FA2FF" />
        <SolidColorBrush x:Key="MutedText" Color="#A5B1C8" />

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="8,8,8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D2D8E3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B2840"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A2437"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#263753"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Border CornerRadius="14" BorderBrush="#5D7FD8" BorderThickness="1" Background="{StaticResource PanelBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#111B2D">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="🛡" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Safe Script Studio" FontWeight="SemiBold" FontSize="14"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="Local Workspace" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="8,10,8,8">
                        <TextBlock Text="⚡" FontSize="24" Foreground="{StaticResource Accent}" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <Button x:Name="ScriptsButton" Style="{StaticResource MenuButtonStyle}" Click="ScriptsButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📜" Margin="0,0,8,0"/>
                                <TextBlock Text="Scripts" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="ConfigButton" Style="{StaticResource MenuButtonStyle}" Click="ConfigButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" Margin="0,0,8,0"/>
                                <TextBlock Text="Config" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="FilesButton" Style="{StaticResource MenuButtonStyle}" Click="FilesButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" Margin="0,0,8,0"/>
                                <TextBlock Text="Files" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Column="1" BorderBrush="#2C3A54" BorderThickness="1,0,1,0" Background="#101827">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,4,0,12">
                                <Button x:Name="TxtFilterButton" Style="{StaticResource ActionButtonStyle}" Width="66" Height="34" Click="TxtFilterButton_Click">
                                    <TextBlock Text="TXT"/>
                                </Button>
                                <Button x:Name="AllFilterButton" Style="{StaticResource ActionButtonStyle}" Width="66" Height="34" Click="AllFilterButton_Click">
                                    <TextBlock Text="ALL"/>
                                </Button>
                            </DockPanel>

                            <TextBox x:Name="ScriptNameTextBox" Grid.Row="1"
                                     Text="SCRIPT NAME"
                                     Background="#1A2638"
                                     Foreground="#E7ECF7"
                                     BorderBrush="{StaticResource Accent}"
                                     BorderThickness="1"
                                     FontSize="24"
                                     FontWeight="Bold"
                                     Padding="8"/>

                            <ListBox x:Name="SavedScriptsList"
                                     Grid.Row="2"
                                     Margin="0,12,0,0"
                                     Background="#0E1522"
                                     BorderBrush="#324766"
                                     BorderThickness="1"
                                     Foreground="#E2E8F0">
                                <ListBoxItem Content="Welcome.lua"/>
                                <ListBoxItem Content="MovementChecks.lua"/>
                                <ListBoxItem Content="EconomyTests.lua"/>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2" Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="12,12,12,8">
                            <Border BorderBrush="{StaticResource Accent}" BorderThickness="1" CornerRadius="8" Padding="12,6" Background="#18253A" DockPanel.Dock="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" Margin="0,0,6,0"/>
                                    <TextBlock Text="Script tab" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="NewScriptButton"
                                    Width="42"
                                    Height="36"
                                    Margin="10,0,0,0"
                                    Background="Transparent"
                                    BorderBrush="#7FA2FF"
                                    BorderThickness="1"
                                    Foreground="#D7E0F5"
                                    Click="NewScriptButton_Click">
                                <TextBlock Text="＋" FontSize="18"/>
                            </Button>
                        </DockPanel>

                        <TextBox x:Name="EditorTextBox"
                                 Grid.Row="1"
                                 Margin="12,0,12,12"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="21"
                                 FontWeight="Bold"
                                 Background="#0D1421"
                                 Foreground="#F4F4F5"
                                 BorderBrush="{StaticResource Accent}"
                                 BorderThickness="1"
                                 Text="-- local script workspace&#10;print(&quot;Ready&quot;)"/>

                        <DockPanel Grid.Row="2" Margin="12,0,12,12" LastChildFill="False">
                            <Button x:Name="RunLocalButton" Style="{StaticResource ActionButtonStyle}" Width="150" Click="RunLocalButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶" Margin="0,0,6,0"/>
                                    <TextBlock Text="RUN LOCAL"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SaveButton" Style="{StaticResource ActionButtonStyle}" Width="118" Click="SaveButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾" Margin="0,0,6,0"/>
                                    <TextBlock Text="SAVE"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="StatusText"
                                       Text="Ready"
                                       Foreground="#A5B4FC"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
